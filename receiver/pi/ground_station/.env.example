# Ground station runtime configuration
# Copy to .env and adjust values.

# Bind + auth
HOST=127.0.0.1
PORT=8000
GS_AUTH_TOKEN=CHANGE_ME_BEFORE_FLIGHT

# Companion UART bridge (Pi <-> ESP32)
# Set to 1 to enable direct Pi <-> ESP32 serial link.
GS_COMPANION_UART=0
GS_COMPANION_UART_PORT=/dev/serial0
GS_COMPANION_UART_BAUD=115200
GS_COMPANION_UART_DEBUG=0

GS_UPS_VIN_MIN_V=3.8
GS_UPS_VBATT_MIN_V=3.1
GS_GROUND_BATT_AUTO_SHUTDOWN=1
GS_GROUND_BATT_WARN_V=6.8
GS_GROUND_BATT_SHUTDOWN_V=6.4
GS_GROUND_BATT_SHUTDOWN_SAMPLES=3
GS_VOLTAGE_MONITOR_SHUTDOWN_CMD=sudo shutdown -h now

# Optional explicit env file path override used by ground_station_server.py
# GS_ENV_FILE=/absolute/path/to/.env
